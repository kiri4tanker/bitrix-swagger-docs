{
	"name": "kiri4tanker/k4t.docs",
	"description": "Автоматическая документация Bitrix на Swagger",
	"type": "bitrix-d7-module",
	"keywords": [
		"bitrix",
		"swagger",
		"docs",
		"kiri4tanker"
	],
	"authors": [
		{
			"name": "Kirill Terentiev",
			"email": "kiri4tankerofficial@gmail.com",
			"role": "Author"
		}
	],
	"autoload": {
		"classmap": [
			"lib/"
		]
	},
	"autoload-dev": {
		"psr-4": {
			"K4T\\Docs\\Tests\\": "tests/"
		}
	},
	"require": {
		"php": ">=8.2",
		"composer/installers": "^1.0|^2.0",
		"zircote/swagger-php": "^4.10"
	},
	"require-dev": {
		"phpunit/phpunit": "^11.5",
		"phpstan/phpstan": "^2.1"
	},
	"support": {
		"docs": "https://github.com/kiri4tanker/bitrix-swagger-docs/blob/main/readme.md",
		"issues": "https://github.com/kiri4tanker/bitrix-swagger-docs/issues",
		"source": "https://github.com/kiri4tanker/bitrix-swagger-docs"
	},
	"scripts": {
		"test": "phpunit --configuration phpunit.xml",
		"stan": "phpstan analyse --configuration phpstan.neon --no-progress",
		"lint": "find . -type f -name '*.php' -not -path './vendor/*' -print0 | xargs -0 -n1 php -l"
	},
	"config": {
		"allow-plugins": {
			"composer/installers": true
		}
	},
	"archive": {
		"exclude": [
			"/.github/",
			"/tests/",
			"/stubs/",
			"/.idea/",
			"/.vscode/",
			"/.phpunit.result.cache",
			"/phpunit.xml",
			"/phpstan.neon",
			"/CHANGELOG.md",
			"/CONTRIBUTING.md",
			"/SECURITY.md"
		]
	},
	"license": "MIT"
}
